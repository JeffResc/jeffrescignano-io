---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

// Self-hosted fonts (eliminates Google Fonts DNS lookups)
import '@fontsource/ibm-plex-sans/300.css';
import '@fontsource/ibm-plex-sans/400.css';
import '@fontsource/ibm-plex-sans/500.css';
import '@fontsource/ibm-plex-sans/600.css';
import '@fontsource/ibm-plex-mono/200.css';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/600.css';

import defaultOgImage from '../assets/jeff.jpg';

interface Props {
	title: string;
	description?: string;
	image?: string;
	canonicalURL?: string;
	type?: 'website' | 'article';
	publishedTime?: string;
	modifiedTime?: string;
	jsonLd?: Record<string, unknown>;
}

const {
	title,
	description = 'Jeff Rescignano - Platform Engineer focused on building tools and infrastructure that help teams ship code easier and faster.',
	image = defaultOgImage.src,
	canonicalURL = new URL(Astro.url.pathname, Astro.site).href,
	type = 'website',
	publishedTime,
	modifiedTime,
	jsonLd,
} = Astro.props;

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
const absoluteImageURL = new URL(image, Astro.site).href;

const websiteJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	name: 'Jeff Rescignano',
	url: Astro.site?.href,
};
---

<!doctype html>
<html lang="en">
	<head>
		<meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="author" content="Jeff Rescignano" />
		<link rel="canonical" href={canonicalURL} />
		<ClientRouter />

		<!-- Open Graph -->
		<meta property="og:type" content={type} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={absoluteImageURL} />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:site_name" content="Jeff Rescignano" />
		{publishedTime && <meta property="article:published_time" content={publishedTime} />}
		{modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={absoluteImageURL} />

		<meta content="width=device-width, initial-scale=1" name="viewport" />
		<link rel="preload" href={defaultOgImage.src} as="image" />
		<meta name="color-scheme" content="dark" />
		<!-- Favicons auto-generated by astro-favicons integration -->
		<link rel="sitemap" href={`${base}sitemap-index.xml`} />
		<link rel="alternate" type="application/rss+xml" title="Jeff Rescignano's Blog" href={`${base}rss.xml`} />
		<meta name="generator" content={Astro.generator} />

		<script type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)} />
		{jsonLd && (
			<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
		)}

	</head>
	<body>
		<slot />
	</body>
</html>
<style is:global>

	:root {
		--accent: 136, 58, 234;
		--accent-light: 224, 204, 250;
		--accent-dark: 49, 10, 101;
		--accent-gradient: linear-gradient(
			45deg,
			rgb(var(--accent)),
			rgb(var(--accent-light)) 30%,
			white 60%
		);
	}
	html {
		font-family: system-ui, sans-serif;
		background: #13151a;
		background-size: 224px;
	}
	code {
		font-family:
			Menlo,
			Monaco,
			Lucida Console,
			Liberation Mono,
			DejaVu Sans Mono,
			Bitstream Vera Sans Mono,
			Courier New,
			monospace;
	}
</style>
