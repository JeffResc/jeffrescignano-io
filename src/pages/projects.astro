---
import { Icon } from 'astro-icon/components';
import Layout from '../layouts/Layout.astro';
import Sidebar from "../components/Sidebar.astro";
import Footer from "../components/Footer.astro";

const projects = [
  {
    name: 'authentik-k8s-operator',
    repo: 'JeffResc/authentik-k8s-operator',
    description: 'A Kubernetes operator for managing Authentik applications declaratively. Define OAuth2/OIDC apps as Custom Resources with automatic credential sync to Kubernetes secrets.',
    tags: ['Identity Management', 'Cloud Native', 'Kubernetes', 'Go'],
  },
  {
    name: 'DisplayLoop',
    repo: 'JeffResc/DisplayLoop',
    description: 'A digital signage management system for controlling multiple screens with scheduled content playback. Features a web interface for managing displays, uploading media, and remote monitoring.',
    tags: ['Go', 'VLC'],
  },
  {
    name: 'hologram-mqtt',
    repo: 'JeffResc/hologram-mqtt',
    descriptionHtml: 'A bridge that integrates <a href="https://hologram.io" target="_blank" rel="noopener noreferrer">Hologram.io</a> cellular IoT devices with Home Assistant through MQTT auto-discovery, exposing devices as native Home Assistant entities.',
    tags: ['IoT', 'Home Automation', 'MQTT', 'Go'],
  },
];

// Fetch GitHub stats for all projects at build time
const projectsWithStats = await Promise.all(
  projects.map(async (project) => {
    try {
      const response = await fetch(`https://api.github.com/repos/${project.repo}`, {
        headers: {
          'Accept': 'application/vnd.github.v3+json',
          'User-Agent': 'jeffrescignano-io',
        },
      });

      if (response.ok) {
        const data = await response.json();
        return {
          ...project,
          stars: data.stargazers_count,
          forks: data.forks_count,
          watchers: data.subscribers_count,
        };
      }
    } catch (_) {
      // Fall through to return without stats
    }
    return { ...project, stars: null, forks: null, watchers: null };
  })
);
---

<Layout title="Projects | Jeff Rescignano" description="Open-source projects by Jeff Rescignano — Kubernetes operators, digital signage, IoT integrations, and more.">
  <div class="content">
    <Sidebar selectedItem="projects" />
    <main class="main">
      <div class="container">
        <div class="content-container">
          <h1>Projects</h1>

          <div class="resouce-items">
            {projectsWithStats.map((project) => (
              <div class="project-card">
                <div class="project-header">
                  <h2>{project.name}</h2>
                  <a href={`https://github.com/${project.repo}`} class="project-link" target="_blank" rel="noopener noreferrer">
                    <Icon name="fa6-brands:github" class="project-link-icon" /> GitHub
                    <Icon name="fa6-solid:up-right-from-square" class="project-link-icon-sm" />
                  </a>
                </div>
                {project.descriptionHtml ? (
                  <p class="project-desc" set:html={project.descriptionHtml} />
                ) : (
                  <p class="project-desc">{project.description}</p>
                )}
                {project.stars !== null && (
                  <div class="project-stats">
                    <span class="project-stat">
                      <Icon name="fa6-solid:star" class="stat-icon" />
                      {project.stars}
                    </span>
                    <span class="project-stat">
                      <Icon name="fa6-solid:code-fork" class="stat-icon" />
                      {project.forks}
                    </span>
                    <span class="project-stat">
                      <Icon name="fa6-solid:eye" class="stat-icon" />
                      {project.watchers}
                    </span>
                  </div>
                )}
                <div class="chips-container">
                  {project.tags.map((tag) => (
                    <div class="single-chip small-chip">{tag}</div>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
      <Footer />
    </main>
  </div>

  <style>
    .resouce-items {
      gap: 24px;
    }

    .project-card {
      background-color: #1c1c1c;
      border: 1px solid #353535;
      border-left: 4px solid #6366f1;
      border-radius: 8px;
      padding: 24px;
    }

    .project-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 12px;
    }

    .project-header h2 {
      margin: 0;
      color: #fff;
      font-family: 'IBM Plex Mono', monospace;
      font-size: 18px;
    }

    .project-link {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 12px;
      background: #6366f1;
      color: white;
      text-decoration: none;
      border-radius: 6px;
      font-size: 13px;
      font-weight: 500;
      white-space: nowrap;
      transition: background-color 0.2s ease;
    }

    .project-link:hover {
      background: #5855eb;
      color: white;
    }

    .project-link-icon {
      width: 16px;
      height: 16px;
    }

    .project-link-icon-sm {
      width: 10px;
      height: 10px;
    }

    .project-card .project-desc {
      margin-bottom: 16px;
    }

    .project-card .chips-container {
      margin-top: 0;
    }

    .project-stats {
      display: flex;
      gap: 16px;
      margin-bottom: 16px;
    }

    .project-stat {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      color: #a8a8a8;
      font-family: 'IBM Plex Mono', monospace;
      font-size: 13px;
    }

    .stat-icon {
      width: 14px;
      height: 14px;
      color: #6366f1;
    }

    @media (max-width: 768px) {
      .project-header {
        flex-direction: column;
        align-items: flex-start;
      }
    }
  </style>
</Layout>
