---
import Layout from '../layouts/Layout.astro';
import Sidebar from "../components/Sidebar.astro";
import Footer from "../components/Footer.astro";

const featuredRepos = [
  { name: 'authentik-k8s-operator', owner: 'JeffResc', tags: ['Identity Management', 'Cloud Native', 'Kubernetes', 'Go'] },
  { name: 'DisplayLoop', owner: 'JeffResc', tags: ['Go', 'VLC'] },
  { name: 'hologram-mqtt', owner: 'JeffResc', tags: ['IoT', 'Home Automation', 'MQTT', 'Go'] },
];

const projects = await Promise.all(
  featuredRepos.map(async (repo) => {
    try {
      const res = await fetch(`https://api.github.com/repos/${repo.owner}/${repo.name}`, {
        headers: { 'Accept': 'application/vnd.github.v3+json' },
      });
      if (res.ok) {
        const data = await res.json();
        return {
          name: data.name,
          description: data.description,
          url: data.html_url,
          stars: data.stargazers_count,
          language: data.language,
          tags: repo.tags,
        };
      }
    } catch {}
    return {
      name: repo.name,
      description: '',
      url: `https://github.com/${repo.owner}/${repo.name}`,
      stars: 0,
      language: null,
      tags: repo.tags,
    };
  })
);
---

<Layout title="Projects | Jeff Rescignano" description="Open-source projects by Jeff Rescignano — Kubernetes operators, digital signage, IoT integrations, and more.">
  <div class="content">
    <Sidebar selectedItem="projects" />
    <main class="main">
      <div class="container">
        <div class="content-container">
          <h1>Projects</h1>

          <div class="resouce-items">
            {projects.map((project) => (
              <div class="project-card">
                <div class="project-header">
                  <h3>{project.name}</h3>
                  <div class="project-header-right">
                    {project.stars > 0 && (
                      <span class="star-count">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="star-icon"><path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z" /></svg>
                        {project.stars}
                      </span>
                    )}
                    <a href={project.url} class="project-link" target="_blank" rel="noopener noreferrer">
                      GitHub
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="external-icon"><path fill-rule="evenodd" d="M4.25 5.5a.75.75 0 0 0-.75.75v8.5c0 .414.336.75.75.75h8.5a.75.75 0 0 0 .75-.75v-4a.75.75 0 0 1 1.5 0v4A2.25 2.25 0 0 1 12.75 17h-8.5A2.25 2.25 0 0 1 2 14.75v-8.5A2.25 2.25 0 0 1 4.25 4h5a.75.75 0 0 1 0 1.5h-5Zm7.5-3.25a.75.75 0 0 0 0 1.5h2.94l-5.72 5.72a.75.75 0 1 0 1.06 1.06l5.72-5.72v2.94a.75.75 0 0 0 1.5 0v-5a.75.75 0 0 0-.75-.75h-5Z" clip-rule="evenodd" /></svg>
                    </a>
                  </div>
                </div>
                <p class="project-desc">{project.description}</p>
                <div class="chips-container">
                  {project.tags.map((tag) => (
                    <div class="single-chip small-chip">{tag}</div>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
      <Footer />
    </main>
  </div>

  <style>
    .resouce-items {
      gap: 24px;
    }

    .project-card {
      background-color: #1c1c1c;
      border: 1px solid #353535;
      border-left: 4px solid #6366f1;
      border-radius: 8px;
      padding: 24px;
    }

    .project-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 12px;
    }

    .project-header h3 {
      margin: 0;
      color: #fff;
      font-family: 'IBM Plex Mono', monospace;
      font-size: 18px;
    }

    .project-header-right {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .star-count {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      color: #a8a8a8;
      font-size: 13px;
      font-weight: 500;
    }

    .star-icon {
      width: 14px;
      height: 14px;
      color: #f59e0b;
    }

    .project-link {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 12px;
      background: #6366f1;
      color: white;
      text-decoration: none;
      border-radius: 6px;
      font-size: 13px;
      font-weight: 500;
      white-space: nowrap;
      transition: background-color 0.2s ease;
    }

    .project-link:hover {
      background: #5855eb;
      color: white;
    }

    .external-icon {
      width: 12px;
      height: 12px;
    }

    .project-card .project-desc {
      margin-bottom: 16px;
    }

    .project-card .chips-container {
      margin-top: 0;
    }

    @media (max-width: 768px) {
      .project-header {
        flex-direction: column;
        align-items: flex-start;
      }
    }
  </style>
</Layout>
