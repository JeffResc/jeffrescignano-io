---
import { getCollection } from 'astro:content';
import Layout from "../layouts/Layout.astro";
import Sidebar from "../components/Sidebar.astro";
import Footer from "../components/Footer.astro";

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function getReadingTime(body: string | undefined): number {
  const plainText = (body || '').replace(/```[\s\S]*?```/g, '').replace(/[#*\[\]()>`_~-]/g, '');
  const wordCount = plainText.split(/\s+/).filter(Boolean).length;
  return Math.max(1, Math.ceil(wordCount / 225));
}
---

<Layout title="Blog | Jeff Rescignano" description="Blog posts by Jeff Rescignano on platform engineering, Kubernetes, home automation, and cloud-native tooling.">
    <div class="content">
      <Sidebar selectedItem="blog" />
      <main class="main">
        <div class="container">
          <div class="content-container">
            <div class="blog-header">
              <h1>Blog</h1>
              <a href="/rss.xml" class="rss-link" target="_blank" rel="noopener noreferrer" aria-label="RSS Feed">
                <i class="fas fa-rss" aria-hidden="true"></i> RSS
              </a>
            </div>
            <section class="items-container">
              <div class="resouce-items">
                {sortedPosts.map((post) => (
                  <div class="resource-single-item blog-post-item">
                    <div class="single-resource-content">
                      <div class="single-resource-content-top">
                        <h3>
                          <a href={`/blog/${post.id}/`} class="blog-title-link">
                            {post.data.title}
                          </a>
                        </h3>
                        <p class="description">{post.data.description}</p>
                        <div class="post-meta-info">
                          <div class="mini-label-white gray-color">
                            {post.data.pubDate.toDateString()} • {getReadingTime(post.body)} min read
                          </div>
                          {post.data.tags && (
                            <div class="chips-container">
                              {post.data.tags.map((tag) => (
                                <div class="single-chip">{tag}</div>
                              ))}
                            </div>
                          )}
                        </div>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </section>
          </div>
        </div>
        <Footer />
      </main>
    </div>

    <style>
      .blog-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .blog-header h1 {
        margin-bottom: 0;
      }

      .rss-link {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 12px;
        color: #a8a8a8;
        border: 1px solid #353535;
        border-radius: 6px;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        transition: color 0.15s ease, border-color 0.15s ease;
      }

      .rss-link:hover {
        color: #fff;
        border-color: #555;
      }
    </style>
</Layout>