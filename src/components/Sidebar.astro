---
import { Icon } from 'astro-icon/components';

const { selectedItem } = Astro.props;
---

<aside
  data-animation="default"
  data-collapse="medium"
  data-duration="400"
  data-easing="ease"
  data-easing2="ease"
  role="banner"
  class="sidebar w-nav"
>
  <div class="nav-content">
    <a href="/" class="w-nav-brand" aria-label="home">
      <div class="niv-data">
        <img
          src="/assets/jeff.jpg"
          loading="eager"
          alt="Profile picture"
          class="niv-image"
        />
        <div>
          <div class="label-white">Jeff Rescignano</div>
          <div class="label-gray">Platform Engineer</div>
        </div>
      </div>
    </a>

    <nav role="navigation" class="w-nav-menu">
      <a
        href="/"
        class={`nav-link-container w-inline-block ${
          selectedItem === 'home' ? 'w--current' : ''
        }`}
      >
        <Icon name="fa6-solid:house" class="nav-link-icon" />
        <div>Home</div>
      </a>
      <a
        href="/blog"
        class={`nav-link-container w-inline-block ${
          selectedItem === 'blog' ? 'w--current' : ''
        }`}
      >
        <Icon name="fa6-solid:feather-pointed" class="nav-link-icon" />
        <div>Blog</div>
      </a>
      <a
        href="/projects"
        class={`nav-link-container w-inline-block ${
          selectedItem === 'projects' ? 'w--current' : ''
        }`}
      >
        <Icon name="fa6-solid:code" class="nav-link-icon" />
        <div>Projects</div>
      </a>
      <a
        href="/certifications"
        class={`nav-link-container w-inline-block ${
          selectedItem === 'certifications' ? 'w--current' : ''
        }`}
      >
        <Icon name="fa6-solid:certificate" class="nav-link-icon" />
        <div>Certifications</div>
      </a>
      <a
        href="https://github.com/JeffResc"
        class="nav-link-container w-inline-block"
        target="_blank"
        rel="noopener noreferrer"
      >
        <Icon name="fa6-brands:github" class="nav-link-icon" />
        <div>GitHub</div>
        <Icon name="fa6-solid:up-right-from-square" class="nav-link-icon" />
      </a>
      <a
        href="https://www.linkedin.com/in/jeffrey-rescignano/"
        class="nav-link-container w-inline-block"
        target="_blank"
        rel="noopener noreferrer"
      >
        <Icon name="fa6-brands:linkedin" class="nav-link-icon" />
        <div>LinkedIn</div>
        <Icon name="fa6-solid:up-right-from-square" class="nav-link-icon" />
      </a>
      <a
        href="https://charts.jeffresc.dev/"
        class="nav-link-container w-inline-block"
        target="_blank"
        rel="noopener noreferrer"
      >
        <Icon name="fa6-solid:anchor" class="nav-link-icon" />
        <div>Helm Charts</div>
        <Icon name="fa6-solid:up-right-from-square" class="nav-link-icon" />
      </a>
    </nav>

    <div
      class="navbar-icon-button w-nav-button"
      style="-webkit-user-select: text;"
      aria-label="menu"
      role="button"
      tabindex="0"
    >
      <Icon name="fa6-solid:bars" class="navbar-icon" />
    </div>
  </div>

  <style>
    .nav-link-icon {
      width: 24px;
      height: 24px;
      opacity: 0.48;
      flex-shrink: 0;
    }
  </style>

  <script>
    import { setupNav } from '../scripts/nav.js';

    let cleanup: (() => void) | undefined;
    document.addEventListener('astro:page-load', () => {
      if (cleanup) cleanup();
      cleanup = setupNav();
    });

    document.addEventListener('astro:before-swap', () => {
      if (cleanup) cleanup();
    });
  </script>
</aside>
